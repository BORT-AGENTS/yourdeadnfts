# Moralis Data-API key(s). Get one at https://admin.moralis.com
# Comma-separated list for rotation (scanner falls back to the next key
# when the current one returns 401/402/429 — i.e. daily CU exhausted).
VITE_MORALIS_API_KEYS=your_first_moralis_key,your_second_moralis_key

# Single-key fallback — used only if VITE_MORALIS_API_KEYS is unset.
# VITE_MORALIS_API_KEY=your_moralis_key
